{
  "m3u": "/path to/VOD.m3u",
  "existing_media_dirs": [
    "/media/Existing"
  ],
  "dry_run": false,
  "max_workers": 8,
  "write_non_us_report": true,
  "notes": {
    "m3u": "Single string (file path or URL) or a list [\"movies.m3u\", \"series.m3u\"] to merge multiple playlists.",
    "output": "All output (logs, cache, STRM files) is written to the 'output/' directory at the project root.",
    "write_non_us_report": "If true, titles excluded by ignore_keywords will be written to excluded_entries.txt for review."
  },
  "tv_group_keywords": [
    "ser",
    "action",
    "adventure",
    "animation",
    "comedy",
    "crime",
    "drama",
    "family",
    "kids",
    "mystery",
    "reality",
    "scifi",
    "western",
    "docs",
    "food"
  ],
  "doc_group_keywords": [
    "doc"
  ],
  "movie_group_keywords": [
    "4k",
    "actionm",
    "adventurem",
    "animationm",
    "comedym",
    "dramam",
    "familym",
    "fantasym",
    "historym",
    "horrorm",
    "kidsm",
    "mysterym",
    "pi3",
    "romancem",
    "sciencefictionm",
    "thrillerm",
    "warm",
    "westernm"
  ],
  "replay_group_keywords": [
    "replays"
  ],
  "ignore_keywords": {
    "tvshows": [
      "ufc",
      "wwe",
      "pokemon",
      "aew"
    ],
    "movies": [
      "ufc",
      "pokemon",
